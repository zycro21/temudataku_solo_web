  // skor otomatis / sistem
  plagiarismScore  Decimal?          @db.Decimal @map("plagiarism_score")
  score            Decimal?          @db.Decimal // agregasi dari seluruh skor penilaian

  // skor per-metriks
  briefScore        String?          @map("brief_score") // kesesuaian brief
  technicalScore    String?          @map("technical_score") // kualitas teknis
  creativityScore   String?          @map("creativity_score") // kreativitas
  completenessScore String?          @map("completeness_score") // kelengkapan

  // feedback mentor
  mentorFeedback   String?           @db.VarChar @map("mentor_feedback") // feedback singkat
  mentorSuggestion String?           @db.VarChar @map("mentor_suggestion") // saran

  // status review
  isReviewed       Boolean?          @default(false) @map("is_reviewed")
  reviewStatus     ReviewStatus      @default(PENDING) @map("review_status") // enum baru
  isRevisedRequired Boolean?         @default(false) @map("is_revised_required")
  revisionDeadline DateTime?         @map("revision_deadline")

  gradedBy         String?           @map("graded_by")
  createdAt        DateTime?         @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt        DateTime?         @db.Timestamp(6) @map("updated_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user             User              @relation("SubmissionByMentee", fields: [menteeId], references: [id], onDelete: Cascade, onUpdate: Cascade) 
  session          MentoringSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  gradedByUser     User?             @relation("SubmissionGradedByMentor", fields: [gradedBy], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("project_submissions")
}

