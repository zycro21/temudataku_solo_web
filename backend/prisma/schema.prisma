generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   @db.VarChar       // contoh: "LOGIN", "CREATE_SERVICE", "UPDATE_PROFILE"
  description String? @db.Text         // detail tambahan
  ipAddress String?  @db.VarChar       // IP user
  userAgent String?  @db.VarChar       // browser info
  type      String?  @db.VarChar       // join, leave, upload, send_message, update_material, dll
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model AYCLBatch {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique

  // HERO
  headline    String   // "All You Can Learn • Data Analyst Program"
  subHeadline String?  // "Upgrade skill Data Analyst..."
  
  description String?  // short intro

  whatsappGroupLink String?

  price       Decimal  @db.Decimal
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  schedules   AYCLSchedule[]
  bookings    AYCLBooking[]
  sections    AYCLSection[]
  materials   AYCLMaterial[]

  @@map("aycl_batches")
}

enum AYCLSectionType {
  PROGRAM_INFO      // "Ini Program Apa?"
  CHALLENGE         // "Biasanya Tantangannya..."
  TARGET            // "Cocok untuk Siapa?"
  DIFFERENTIATOR    // "Kenapa AYCL .... berbeda?"
  BENEFIT           // "Apa yang kamu dapatkan?"
  CLOSING           // penutup
}

model AYCLSection {
  id        String   @id @default(cuid())
  batchId   String
  type      AYCLSectionType
  title     String

  /// JSON structure:
  /// PROGRAM_INFO      => { text: string }
  /// CHALLENGE         => { items: string[] }
  /// TARGET            => { items: string[] }
  /// DIFFERENTIATOR    => { items: { title: string, desc: string }[] }
  /// BENEFIT           => { items: string[] }
  /// CLOSING           => { text: string }
  content   Json

  order     Int

  batch     AYCLBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("aycl_sections")
  @@index([batchId, order])
}

model AYCLMaterial {
  id        String @id @default(cuid())
  batchId   String
  title     String
  description String?

  batch     AYCLBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("aycl_materials")
}

model AYCLSchedule {
  id          String   @id @default(cuid())
  batchId     String
  title       String
  date        DateTime

  startTime   DateTime
  endTime     DateTime

  googleMeetLink String?

  quota       Int?
  createdAt   DateTime @default(now())

  batch       AYCLBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  participants AYCLParticipant[]

  @@index([batchId])
  @@map("aycl_schedules")
}

model AYCLBooking {
  id              String   @id @default(cuid())
  userId          String
  batchId         String
  referralUsageId String?  @unique
  status          String   // pending, confirmed, completed, cancelled
  createdAt       DateTime @default(now())

  currentStatus   String?
  institution     String?
  studyProgram    String?
  semester        String?
  age             Int?
  reason          String?  @db.Text
  familiarity     String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch       AYCLBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  payment     Payment?
  referralUsage ReferralUsage? @relation("ReferralUsageAYCL", fields: [referralUsageId], references: [id])

  participants AYCLParticipant[]

  @@map("aycl_bookings")
}

model AYCLParticipant {
  id          String   @id @default(cuid())
  bookingId   String
  scheduleId  String
  createdAt   DateTime @default(now())

  booking     AYCLBooking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  schedule    AYCLSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([bookingId, scheduleId])
  @@map("aycl_participants")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Booking {
  id                  String              @id @default(cuid())
  menteeId            String
  mentoringServiceId  String              @map("mentoring_service_id")
  referralUsageId     String?             @unique
  bookingDate         DateTime?           @default(now())
  status              String?             @db.VarChar
  specialRequests     String?
  material            String?             // materi yang diminta mentee
  expectedOutput      String?             // ekspektasi output dari mentee
  supportDocument     String?             // dokumen tambahan dari mentee
  createdAt           DateTime?           @default(now())
  updatedAt           DateTime?

  // Relations
  mentee              User                @relation(fields: [menteeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  mentoringService    MentoringService    @relation(fields: [mentoringServiceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referralUsage       ReferralUsage?      @relation("ReferralUsageBooking", fields: [referralUsageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  payment             Payment?            @relation("BookingPayment") // satu payment untuk booking
  participants        BookingParticipant[]

  @@map("bookings")
}

model BookingParticipant {
  id             String   @id @default(cuid())
  bookingId      String
  userId         String
  paymentStatus  String   // 'pending', 'confirmed', etc.
  paymentId      String?  @map("payment_id")
  isLeader       Boolean  @default(false)

  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment        Payment? @relation("ParticipantPayment", fields: [paymentId], references: [id])

  @@map("booking_participants")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Certificate {
  id                String            @id @default(cuid())
  menteeId          String            @map("mentee_id")
  serviceId         String            @map("service_id")
  certificateNumber String            @unique @db.VarChar @map("certificate_number")
  issueDate         DateTime?         @default(now()) @db.Timestamp(6) @map("issue_date")
  certificatePath   String?           @db.VarChar @map("certificate_path")
  googleDriveUrl    String?           @db.VarChar @map("google_drive_url") //
  projectCertificatePath String?      @db.VarChar @map("project_certificate_path")
  status            String?           @db.VarChar @map("status") // generated, sent, viewed
  verifiedBy        String?           @db.VarChar @map("verified_by") // ID dari admin/mentor yang verifikasi (optional)
  note              String?           @db.VarChar @map("note") // Catatan internal admin (optional)
  createdAt         DateTime?         @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt         DateTime?         @db.Timestamp(6) @map("updated_at")

  user              User              @relation(fields: [menteeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  mentoringService  MentoringService  @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([menteeId, serviceId])
  @@map("certificates")
}

model CommissionPayments {
  id              String       @id @default(cuid())
  referralCodeId  String       @map("referral_code_id")
  amount          Decimal
  transactionId   String?      @map("transaction_id")
  status          String?      // pending, paid, failed
  paid_at         DateTime?
  notes           String?      // catatan tambahan atau alasan penolakan/gagal bayar
  created_at      DateTime     @default(now())

  referralCode    ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("commission_payments")
}

model ExportLog {
  id         String    @id @default(cuid())
  entity     String    @db.VarChar     // contoh: "users", "projects", "certificates"
  type       String    @db.VarChar     // "all" atau "filter"
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("export_logs")
}

model ELearningCourse {
  id                String              @id @default(cuid())
  mentorId          String              @map("mentor_id")
  title             String              @db.VarChar
  description       String?
  thumbnailImages   String[]            @db.VarChar @map("thumbnail_images")
  category          String?             @db.VarChar
  tags              String[]            @db.VarChar
  targetAudience    String?             @db.VarChar
  level             String?             @db.VarChar // Beginner, Intermediate, Advanced
  estimatedDuration String?             @db.VarChar
  benefits          String?
  toolsUsed         String?
  isActive          Boolean?            @default(true) @map("is_active")
  slug              String?              @unique
  status            CourseStatus?        @default(DRAFT)
  createdAt         DateTime?           @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt         DateTime?           @db.Timestamp(6) @map("updated_at")

  // Relations
  mentorProfile     MentorProfile       @relation("MentorCourses", fields: [mentorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  subChapters       ELearningSubChapter[]
  reviews           ELearningReview[]
  certificates      ELearningCertificate[]
  discussions       ELearningDiscussion[]

  @@map("e_learning_courses")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ELearningSubChapter {
  id              String            @id @default(cuid())
  courseId        String            @map("course_id")
  title           String            @db.VarChar
  coverImage      String?
  description     String?
  orderNumber     Int               @map("order_number")
  estimatedTime   String?           @db.VarChar
  taskType        TaskType?         @map("task_type")
  status          CourseStatus      @default(DRAFT)
  createdAt       DateTime?         @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt       DateTime?         @db.Timestamp(6) @map("updated_at")

  // Relations
  course          ELearningCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  subBabs         ELearningSubBab[]
  progresses      ELearningSubChapterProgress[]

  @@map("e_learning_sub_chapters")
}

enum TaskType {
  QUIZ
  PROJECT
  QUIZ_AND_PROJECT
}

model ELearningSubBab {
  id              String            @id @default(cuid())
  subChapterId    String            @map("sub_chapter_id")
  title           String            @db.VarChar
  orderNumber     Int?
  estimatedTime   String?           @db.VarChar
  status          CourseStatus @default(DRAFT)
  createdAt       DateTime?         @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt       DateTime?         @db.Timestamp(6) @map("updated_at")

  // Relations
  subChapter      ELearningSubChapter @relation(fields: [subChapterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  texts           ELearningText[]      
  quiz            ELearningQuiz?
  assignment      ELearningAssignment?
  progresses      ELearningProgress[]
  bookmarks       ELearningBookmark[]

  @@map("e_learning_sub_babs")
}

// Tabel baru untuk menyimpan teks/penjelasan materi per SubBab
model ELearningText {
  id           String @id @default(cuid())
  subBabId     String @map("sub_bab_id")
  title        String? @db.VarChar
  orderNumber  Int?
  status       CourseStatus @default(DRAFT)

  createdAt    DateTime? @default(now())
  updatedAt    DateTime? @default(now())

  subBab       ELearningSubBab @relation(fields: [subBabId], references: [id], onDelete: Cascade)
  blocks       ELearningTextBlock[]
  progresses   ELearningTextProgress[] 

  @@index([subBabId])
  @@map("e_learning_texts")
}

model ELearningTextBlock {
  id        String   @id @default(cuid())
  textId    String   @map("text_id")
  orderNumber Int?
  createdAt DateTime? @default(now())

  text      ELearningText @relation(fields: [textId], references: [id], onDelete: Cascade)

  contentBlocks     ELearningContentBlock[]
  additionalContents ELearningAdditionalContent[]
  progresses ELearningBlockProgress[]

  @@unique([textId, orderNumber])
  @@map("e_learning_text_blocks")
}

model ELearningContentBlock {
  id          String   @id @default(cuid())
  blockId     String   @map("block_id")

  type        ContentBlockType
  orderNumber Int?

  createdAt   DateTime? @default(now())

  block       ELearningTextBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  headingContent     ELearningHeadingContent?
  paragraphContent   ELearningParagraphContent?
  accordionContent   ELearningAccordionContent?
  carouselContent    ELearningCarouselContent?
  contentCardContent ELearningContentCardContent?
  tabContent         ELearningTabNavigationContent?
  highlightContent   ELearningHighlightContent?
  summaryContent     ELearningSummaryContent?

  @@map("e_learning_content_blocks")
}

enum ContentBlockType {
  HEADING
  PARAGRAPH
  ACCORDION
  CAROUSEL
  CONTENT_CARD
  TAB_NAVIGATION
  HIGHLIGHT
  SUMMARY
}

model ELearningHeadingContent {
  id          String @id @default(cuid())
  contentId   String @unique

  level       Int
  text        String @db.Text

  content     ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningParagraphContent {
  id        String @id @default(cuid())
  contentId String @unique

  text      String @db.Text

  content   ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningHighlightContent {
  id        String @id @default(cuid())
  contentId String @unique

  text      String @db.VarChar(120)

  content   ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

// Accordion Content
model ELearningAccordionContent {
  id        String @id @default(cuid())
  contentId String @unique

  title       String
  description String?

  items ELearningAccordionItem[]

  content ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningAccordionItem {
  id          String @id @default(cuid())
  accordionId String

  title       String
  content     String
  orderNumber Int

  accordion ELearningAccordionContent @relation(fields: [accordionId], references: [id], onDelete: Cascade)
}

// Carousel Content
model ELearningCarouselContent {
  id String @id @default(cuid())
  contentId String @unique

  title String
  description String?
  cardsPerSlide Int?

  items ELearningCarouselItem[]

  content ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningCarouselItem {
  id String @id @default(cuid())
  carouselId String

  title String
  image String?
  content String?
  orderNumber Int

  carousel ELearningCarouselContent @relation(fields: [carouselId], references: [id], onDelete: Cascade)
}

// Content Card
model ELearningContentCardContent {
  id        String @id @default(cuid())
  contentId String @unique

  title       String
  description String?

  disableExpandableContent Boolean

  items ELearningContentCardItem[]

  content ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningContentCardItem {
  id           String @id @default(cuid())
  cardId       String

  title        String
  content      String
  expandableContent String?

  orderNumber  Int

  card ELearningContentCardContent @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

// Tab Navigation
model ELearningTabNavigationContent {
  id        String @id @default(cuid())
  contentId String @unique

  title       String
  description String?

  tabs ELearningTabItem[]

  content ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningTabItem {
  id        String @id @default(cuid())
  tabId     String

  title     String
  content   String
  orderNumber Int

  tab ELearningTabNavigationContent @relation(fields: [tabId], references: [id], onDelete: Cascade)
}

// Summary
model ELearningSummaryContent {
  id        String @id @default(cuid())
  contentId String @unique

  comments ELearningSummaryComment[]

  content ELearningContentBlock @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ELearningSummaryComment {
  id         String @id @default(cuid())
  summaryId  String

  comment    String
  orderNumber Int

  summary ELearningSummaryContent @relation(fields: [summaryId], references: [id], onDelete: Cascade)
}

// Additional Content
model ELearningAdditionalContent {
  id        String @id @default(cuid())

  blockId   String @map("block_id")

  type      AdditionalContentType
  position  AnchorPosition

  orderNumber Int?

  block ELearningTextBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  video           ELearningImageVideoContent?
  multipleChoice  ELearningMultipleChoiceQuestion?
  matching        ELearningMatchingQuestion?
  code            ELearningExecutableCode?

  @@map("e_learning_additional_contents")
}

enum AdditionalContentType {
  IMAGE_VIDEO
  MULTIPLE_CHOICE
  MATCHING
  INTERACTIVE_CODE
}

enum AnchorPosition {
  BEFORE
  AFTER
  INLINE
}

model ELearningMatchingQuestion {
  id String @id @default(cuid())

  additionalContentId String @unique @map("additional_content_id")

  title String?
  instruction String?
  maxScore Float? @default(100)
  explanation String? @db.Text

  createdAt DateTime? @default(now())

  additionalContent ELearningAdditionalContent @relation(fields: [additionalContentId], references: [id], onDelete: Cascade)

  items ELearningMatchingItem[]

  @@map("e_learning_matching_questions")
}

model ELearningMatchingItem {
  id          String   @id @default(cuid())
  questionId  String   @map("question_id")

  content     String   @db.Text
  side        MatchingItemSide
  orderNumber Int

  matchWithId String?  @map("match_with_id")

  question    ELearningMatchingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("e_learning_matching_items")
}

enum MatchingItemSide {
  LEFT
  RIGHT
}

model ELearningMultipleChoiceQuestion {
  id String @id @default(cuid())
  additionalContentId String @unique
  question String @db.Text
  description String?
  allowMultiple Boolean @default(false)
  explanation String?

  options ELearningMultipleChoiceOption[]
  additionalContent ELearningAdditionalContent @relation(fields: [additionalContentId], references: [id], onDelete: Cascade)
}

model ELearningMultipleChoiceOption {
  id          String   @id @default(cuid())
  questionId  String
  content     String
  isCorrect   Boolean  @default(false)
  orderNumber Int

  question    ELearningMultipleChoiceQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ELearningImageVideoContent {
  id String @id @default(cuid())
  additionalContentId String @unique
  title String?
  caption String?
  description String?
  mediaType MediaType
  url String
  thumbnailUrl String?
  durationSeconds Int?
  createdAt DateTime? @default(now())

  additionalContent ELearningAdditionalContent @relation(fields: [additionalContentId], references: [id], onDelete: Cascade)
  @@map("e_learning_image_video_contents")
}

enum MediaType {
  IMAGE
  VIDEO
}

model ELearningExecutableCode {
  id String @id @default(cuid())

  additionalContentId String @unique @map("additional_content_id")

  title String? @db.VarChar
  description String? @db.Text

  language CodeLanguage
  initialCode String @db.Text
  isEditable Boolean @default(true)
  expectedResult String? @db.Text

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())

  additionalContent ELearningAdditionalContent @relation(fields: [additionalContentId], references: [id], onDelete: Cascade)

  runs ELearningCodeRun[]
  @@map("e_learning_executable_codes")
}

enum CodeLanguage {
  PYTHON
  JAVASCRIPT
  CPP
  SQL
  R
}

model ELearningCodeRun {
  id            String   @id @default(cuid())

  executableId  String   @map("executable_id")
  userId        String   @map("user_id")

  input         String?  @db.Text
  output        String?  @db.Text
  error         String?  @db.Text

  executedAt    DateTime? @default(now())
  executionTime Int?
  isSuccess     Boolean?  @default(false)

  executable    ELearningExecutableCode @relation(fields: [executableId], references: [id], onDelete: Cascade)
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([executableId])
  @@index([userId])
  @@map("e_learning_code_runs")
}

model ELearningQuiz {
  id               String              @id @default(cuid())
  subBabId         String              @unique @map("sub_bab_id")
  title            String              @db.VarChar
  description      String?
  totalQuestions   Int?
  timeLimitMinutes Int?
  createdAt        DateTime?           @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt        DateTime?           @db.Timestamp(6) @map("updated_at")

  subBab           ELearningSubBab     @relation(fields: [subBabId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  questions        ELearningQuestion[]
  quizAttempts     ELearningQuizAttempt[]

  @@map("e_learning_quizzes")
}

model ELearningQuestion {
  id              String            @id @default(cuid())
  quizId          String            @map("quiz_id")
  questionText    String            @db.Text
  options         String[]          @db.VarChar
  correctAnswer   String            @db.VarChar
  explanation     String?
  orderNumber     Int?
  createdAt       DateTime?         @default(now())

  quiz            ELearningQuiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("e_learning_questions")
}

model ELearningQuizAttempt {
  id              String             @id @default(cuid())
  quizId          String             @map("quiz_id")
  userId          String             @map("user_id")
  score           Int?
  startedAt       DateTime?          @default(now())
  completedAt     DateTime?
  answers         Json?              @db.JsonB

  // tambahan
  isAutoGraded    Boolean?           @default(true)
  gradedBy        String?            @map("graded_by")
  gradedAt        DateTime?
  remarks         String?            // catatan dari mentor kalau ada review manual

  quiz            ELearningQuiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
  @@map("e_learning_quiz_attempts")
}

model ELearningAssignment {
  id               String              @id @default(cuid())
  subBabId         String              @unique @map("sub_bab_id")
  title            String              @db.VarChar
  description      String?
  dueDays          Int?
  createdAt        DateTime?           @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt        DateTime?           @db.Timestamp(6) @map("updated_at")

  subBab           ELearningSubBab     @relation(fields: [subBabId], references: [id], onDelete: Cascade)
  submissions      ELearningSubmission[]

  @@map("e_learning_assignments")
}

model ELearningSubmission {
  id              String                    @id @default(cuid())
  assignmentId    String                    @map("assignment_id")
  userId          String                    @map("user_id")
  notes           String?
  files           String[]                  @db.VarChar
  submittedAt     DateTime?                 @default(now())
  status          ELearningSubmissionStatus @default(PENDING)
  reviewedById    String?                   @map("reviewed_by_id")
  reviewedAt      DateTime?

  feedback        String?
  score           Int?

  // tambahan
  gradeBreakdown      Json?     @db.JsonB // contoh: {"content":8,"structure":9,"creativity":7}
  isRevisionRequired  Boolean?  @default(false)
  revisionDeadline     DateTime?

  assignment      ELearningAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user            User                @relation("ELearningSubmittedBy", fields: [userId], references: [id])
  reviewer        User?               @relation("ELearningReviewedBy", fields: [reviewedById], references: [id])

  @@unique([assignmentId, userId])
  @@map("e_learning_submissions")
}

enum ELearningSubmissionStatus {
  PENDING
  REVIEWED
  REVISION_REQUIRED
  APPROVED
  REJECTED
}

model ELearningSubscriptionPlan {
  id          String    @id @default(cuid())
  name        String    @db.VarChar // Monthly, Quarterly, Yearly
  durationDay Int       // 30, 90, 365
  price       Decimal   @db.Decimal
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  subscriptions ELearningSubscription[]

  @@map("e_learning_subscription_plans")
}

model ELearningSubscription {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  referralUsageId String?  @unique
  startAt         DateTime
  endAt           DateTime
  status          String
  createdAt       DateTime @default(now())
