  ownerId               String
  code                  String           @unique
  discountPercentage    Decimal
  commissionPercentage  Decimal
  createdDate           DateTime?        @default(now())
  expiryDate            DateTime?
  isActive              Boolean?         @default(true)
  createdAt             DateTime?        @default(now())
  updatedAt             DateTime?

  owner                 User             @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  usages                ReferralUsage[]
  referralCommisions    ReferralCommisions[]
  commissionPayments    CommissionPayments[]

  @@map("referral_codes")
}

model ReferralUsage {
  id               String             @id @default(cuid())
  userId           String
  referralCodeId   String
  usedAt           DateTime           @default(now())
  context          String             @db.VarChar
  createdAt        DateTime           @default(now())
  updatedAt        DateTime?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referralCode     ReferralCode       @relation(fields: [referralCodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  booking               Booking?           @relation("ReferralUsageBooking")
  practicePurchase      PracticePurchase?  @relation("ReferralUsagePracticePurchase")
  eLearningSubscription ELearningSubscription? @relation("ReferralUsageELearningSubscription")
  ayclBooking           AYCLBooking?       @relation("ReferralUsageAYCL")

  @@unique([userId, referralCodeId])
  @@map("referral_usages")
}

model Role {
  id          String       @id @default(cuid())
  roleName    String       @unique @db.VarChar @map("role_name")
  description String?
  createdAt   DateTime?    @default(now()) @db.Timestamp(6) @map("created_at")

  userRoles   UserRole[]

  @@map("roles")
}

model ShortLink {
  id              String    @id @default(cuid())
  shortCode       String    @unique @map("short_code")
  originalUrl     String    @db.VarChar @map("original_url")
  createdById     String?   @map("created_by_id")
  expiresAt       DateTime? @map("expires_at")
  clickCount      Int       @default(0) @map("click_count")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  createdBy       User?     @relation("UserShortLinks", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("short_links")
}

model UserActivityLog {
  id           String   @id @default(cuid())
  userId       String
  page         String
  durationSec  Int       @default(0)
  accessedAt   DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity_logs")
}

model UserBehavior {
  id          String     @id @default(cuid())
  userId      String?    @map("user_id")
  pageVisited String     @db.VarChar @map("page_visited")
  action      String?    @db.VarChar
  timestamp   DateTime?  @default(now()) @db.Timestamp(6)
  ipAddress   String?    @db.VarChar @map("ip_address")
  userAgent   String?    @db.VarChar @map("user_agent")
  createdAt   DateTime?  @default(now()) @db.Timestamp(6) @map("created_at")

  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_behavior")
}

model UserRole {
  id            String     @id @default(cuid())
  userId        String     @map("user_id")
  roleId        String     @map("role_id")
  assignedDate  DateTime?  @default(now()) @db.Timestamp(6) @map("assigned_date")
  createdAt     DateTime?  @default(now()) @db.Timestamp(6) @map("created_at")

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_roles")
}

model User {
  id                         String              @id @default(cuid())
  email                      String              @unique @db.VarChar
  passwordHash               String?              @db.VarChar @map("password_hash")
  googleId                   String?             @unique
  fullName                   String              @db.VarChar @map("full_name")
  phoneNumber                String?             @db.VarChar @map("phone_number")
  profilePicture             String?             @db.VarChar @map("profile_picture")
  city                       String?             @db.VarChar
  province                   String?             @db.VarChar
  isEmailVerified            Boolean?            @default(false) @map("is_email_verified")
  verificationToken          String?             @db.VarChar @map("verification_token")
  verificationTokenExpires   DateTime?           @db.Timestamp(6) @map("verification_token_expires")
  registrationDate           DateTime?           @default(now()) @db.Timestamp(6) @map("registration_date")
  lastLogin                  DateTime?           @db.Timestamp(6) @map("last_login")
  isActive                   Boolean?            @default(true) @map("is_active")
  fcmToken                   String?             @db.VarChar
  createdAt                  DateTime?           @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt                  DateTime?           @db.Timestamp(6) @map("updated_at")
  instagram                  String?             @db.VarChar
  twitter                    String?             @db.VarChar
  youtube                    String?             @db.VarChar
  tiktok                     String?             @db.VarChar
  otherSocialMedia           String?             @db.VarChar

  adminActivityLogs          AdminActivityLog[]
  bookings                   Booking[]
  bookingParticipants        BookingParticipant[]
  certificates               Certificate[]
  feedback                   Feedback[]
  mentorProfile              MentorProfile?      
  notificationRecipients     NotificationRecipient[]
  practiceProgress           PracticeProgress[]
  practicePurchases          PracticePurchase[]
  practiceReviews            PracticeReview[]
  projectSubmissions         ProjectSubmission[]      @relation("SubmissionByMentee")
  practiceSubmissions        PracticeSubmission[]     @relation("PracticeSubmittedBy") // mentee
  reviewedSubmissions        PracticeSubmission[]     @relation("PracticeReviewedBy") // mentor reviewer
  gradedSubmissions          ProjectSubmission[]      @relation("SubmissionGradedByMentor")
  referralCodes              ReferralCode[]
  referralUsages             ReferralUsage[]
  activityLogs               UserActivityLog[]
  userBehavior               UserBehavior[]
  userRoles                  UserRole[]
  withdrawalMethods          WithdrawalMethod[] 
  shortLinks                 ShortLink[]              @relation("UserShortLinks")
  eLearningSubscriptions     ELearningSubscription[]
  eLearningReviews           ELearningReview[]
  eLearningProgress          ELearningProgress[]
  eLearningSubChapterProgress ELearningSubChapterProgress[]
  eLearningBlockProgress     ELearningBlockProgress[]
  eLearningTextProgress      ELearningTextProgress[]
  quizAttempts               ELearningQuizAttempt[]
  eLearningSubmissions         ELearningSubmission[]     @relation("ELearningSubmittedBy")
  eLearningReviewedSubmissions ELearningSubmission[]     @relation("ELearningReviewedBy") // RENAMED to avoid conflict
  eLearningCertificates      ELearningCertificate[]
  eLearningDiscussions       ELearningDiscussion[]
  eLearningBookmarks         ELearningBookmark[]
  codeRuns                   ELearningCodeRun[] 
  ayclBookings               AYCLBooking[]

  @@map("users")
}

model WithdrawalMethod {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") // affiliator
  type          String   // "bank", "eWallet"
  providerName  String   // "BCA", "Mandiri, "Dana", "OVO"
  accountNumber String   // nomor rekening / nomor HP
  accountName   String?  // nama pemilik akun
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("withdrawal_methods")
}
